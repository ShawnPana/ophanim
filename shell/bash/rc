# ophanim bash integration. Loaded via `bash --rcfile <this>` when a
# ophanim pane spawns bash. Source the user's real rc first so their
# environment is unchanged, then re-prepend $OPHANIM_BIN to PATH —
# macOS path_helper (from /etc/profile) otherwise wipes it on login shells.
if [ -f "$HOME/.bashrc" ]; then
  . "$HOME/.bashrc"
fi
if [ -n "$OPHANIM_BIN" ]; then
  case ":$PATH:" in
    *":$OPHANIM_BIN:"*) ;;
    *) export PATH="$OPHANIM_BIN:$PATH" ;;
  esac
fi
