#!/usr/bin/env bash
# ophanim — dispatcher for ophanim subcommands.
set -e
here="$(cd "$(dirname "$0")" && pwd)"
cmd="${1:-help}"
shift || true

case "$cmd" in
  browse)
    exec "$here/browse" "$@"
    ;;
  config)
    exec "$here/config" "$@"
    ;;
  help|-h|--help|'')
    cat <<'USAGE'
ophanim — commands for the ophanim terminal.

  ophanim browse [url]   Turn the focused pane into a browser.
  ophanim config         Open ~/.config/ophanim/config.json in $EDITOR.

Shorthand: `browse` and `config` are aliases for the above.
USAGE
    ;;
  *)
    echo "ophanim: unknown subcommand '$cmd'" >&2
    echo "try: ophanim help" >&2
    exit 1
    ;;
esac
